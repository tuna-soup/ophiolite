---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { enterpriseMailto, evaluationMailto, teamMailto } from "../data/contact";

const plans = [
  {
    name: "Evaluation",
    summary: "Use this when you need to validate chart-family fit, wrapper shape, and rollout constraints before committing to a license.",
    points: [
      "Launch-family examples and docs alignment",
      "Direct evaluation intake by email",
      "Fit assessment around current JS and Svelte surfaces"
    ],
    cta: "Start Evaluation",
    href: evaluationMailto
  },
  {
    name: "Team",
    summary: "Commercial access for product teams shipping against the supported wrapper surface and documented launch families.",
    points: [
      "Team licensing around the supported product surface",
      "Implementation guidance during integration",
      "Priority issue handling for supported flows"
    ],
    cta: "Discuss Team Access",
    href: teamMailto
  },
  {
    name: "Enterprise",
    summary: "For larger programs that need rollout planning, support expectations, and alignment around long-lived product ownership.",
    points: [
      "Enterprise rollout support and planning",
      "Escalation path for serious delivery programs",
      "Commercial alignment for larger deployments"
    ],
    cta: "Talk Enterprise",
    href: enterpriseMailto
  }
];
---

<MarketingLayout
  title="Pricing | Ophiolite Charts"
  description="Evaluation, team licensing, and enterprise support for Ophiolite Charts."
>
  <section class="page-intro">
    <p class="eyebrow">Pricing</p>
    <h1>Commercial packaging for teams evaluating and shipping a focused chart surface.</h1>
    <p>
      The launch scope is narrow on purpose, so the pricing story is narrow too. The site should make it obvious how to start an evaluation, when to move to a team license, and when an enterprise rollout conversation is justified.
    </p>
  </section>

  <section class="pricing-grid">
    {plans.map((plan) => (
      <article class="pricing-card">
        <p class="pricing-card__eyebrow">Commercial Access</p>
        <h2>{plan.name}</h2>
        <p>{plan.summary}</p>
        <ul class="pricing-card__list">
          {plan.points.map((point) => <li>{point}</li>)}
        </ul>
        <a href={plan.href} class="button button--primary">{plan.cta}</a>
      </article>
    ))}
  </section>

  <section class="content-band">
    <div class="section-heading">
      <p class="eyebrow">What To Send</p>
      <h2>Good evaluation emails are specific.</h2>
      <p>
        The fastest path is a short message that states the chart families you care about, which wrapper you need first, and what makes the rollout commercially meaningful.
      </p>
    </div>
    <div class="value-grid">
      <article>
        <h3>Technical scope</h3>
        <p>List the chart families, data shape, and wrapper surface you need to validate first.</p>
      </article>
      <article>
        <h3>Product scope</h3>
        <p>Explain whether this is a prototype, a team rollout, or an enterprise delivery program.</p>
      </article>
      <article>
        <h3>Decision blockers</h3>
        <p>Call out the interaction, performance, or support questions that have to be answered before you proceed.</p>
      </article>
      <article>
        <h3>Timeline</h3>
        <p>Include when you need an answer so the conversation can match the urgency of the project.</p>
      </article>
    </div>
  </section>

  <section class="content-band content-band--accent">
    <div class="section-heading">
      <p class="eyebrow">Current Commercial Policy</p>
      <h2>Sell what exists, document what is stable, and leave the rest clearly marked.</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Launch wrappers first</h3>
        <p>JavaScript and Svelte support are the public entry points today, so pricing and support center on those paths.</p>
      </article>
      <article>
        <h3>Scope by chart family</h3>
        <p>The contract is easier to trust when each supported family has explicit boundaries instead of a vague platform promise.</p>
      </article>
      <article>
        <h3>Examples and docs stay aligned</h3>
        <p>Commercial discussions should not get ahead of the examples and docs that engineers will actually use during evaluation.</p>
      </article>
      <article>
        <h3>Enterprise support is real support</h3>
        <p>That tier is for rollout planning and execution, not just a renamed email inbox.</p>
      </article>
    </div>
    <div class="cta-band__actions">
      <a href={evaluationMailto} class="button button--primary">Email Evaluation Intake</a>
      <a href="/examples/" class="button button--ghost">Browse Launch Examples</a>
    </div>
  </section>
</MarketingLayout>
