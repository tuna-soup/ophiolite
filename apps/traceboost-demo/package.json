{
  "name": "@ophiolite/traceboost-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "setup:bun-links": "bun run doctor",
    "doctor": "bun run ./scripts/verify-local-deps.mjs",
    "check:ophiolite-boundary": "bun run ./scripts/check-ophiolite-boundary.mjs",
    "generate:desktop-bridge-stubs": "node ./scripts/generate-desktop-bridge-stubs.mjs",
    "dev": "vite",
    "build": "vite build",
    "test": "bun test",
    "typecheck": "bun run generate:desktop-bridge-stubs && bun run check:ophiolite-boundary && svelte-check --tsconfig ./tsconfig.json",
    "tauri:dev": "bun run typecheck && bun run ./scripts/tauri-dev.mjs",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "svelte": "^5.39.6"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@tauri-apps/cli": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "svelte-check": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
