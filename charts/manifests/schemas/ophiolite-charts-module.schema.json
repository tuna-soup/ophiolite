{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ophiolite.dev/schemas/ophiolite-charts-module.schema.json",
  "title": "Ophiolite Charts Module Manifest",
  "description": "Small package-level manifest for Ophiolite Charts support tiers, exports, and consumer guarantees.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "kind",
    "id",
    "displayName",
    "layer",
    "supportTier",
    "description",
    "entrypoints",
    "dependsOn",
    "testPolicy",
    "consumerGuarantees"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "ophioliteChartsModule"
    },
    "id": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "layer": {
      "enum": ["models", "core", "renderer", "domain", "wrapper", "toolbar"]
    },
    "supportTier": {
      "enum": ["public-launch", "public-adapter", "preview", "internal"]
    },
    "description": {
      "type": "string"
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subpath", "tier", "description"],
        "properties": {
          "subpath": {
            "type": "string"
          },
          "tier": {
            "enum": ["public-launch", "public-adapter", "preview", "internal"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role"],
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "enum": ["runtime", "adapter-runtime", "peer", "preview-runtime", "test-only"]
          },
          "optional": {
            "type": "boolean"
          }
        }
      }
    },
    "testPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredSuites", "releaseBlocking"],
      "properties": {
        "requiredSuites": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "releaseBlocking": {
          "type": "boolean"
        }
      }
    },
    "consumerGuarantees": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceboostApproved", "externalConsumerApproved"],
      "properties": {
        "traceboostApproved": {
          "type": "boolean"
        },
        "externalConsumerApproved": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
