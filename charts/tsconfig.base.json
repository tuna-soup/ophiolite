{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@ophiolite/contracts": ["../contracts/ts/ophiolite-contracts/src/index.ts"],
      "@ophiolite/charts-data-models": ["packages/data-models/src/index.ts"],
      "@ophiolite/charts-core": ["packages/chart-core/src/index.ts"],
      "@ophiolite/charts-renderer": ["packages/renderer/src/index.ts"],
      "@ophiolite/charts-domain": ["packages/domain-geoscience/src/index.ts"],
      "@ophiolite/charts": ["packages/svelte/src/index.ts"],
      "@ophiolite/charts-toolbar": ["packages/svelte-toolbar/src/index.ts"]
    },
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  }
}
