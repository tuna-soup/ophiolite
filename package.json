{
  "name": "ophiolite-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/ophiolite-docs",
    "apps/ophiolitecharts-docs",
    "charts"
  ],
  "scripts": {
    "docs:dev": "bun --filter ophiolite-docs dev",
    "docs:build": "bun --filter ophiolite-docs build",
    "charts-site:dev": "bun --filter ophiolitecharts-docs dev",
    "charts-site:dev:with-live": "bun --filter ophiolitecharts-docs dev:with-live",
    "charts-site:build": "bun --filter ophiolitecharts-docs build",
    "charts-site:preview": "bun --filter ophiolitecharts-docs preview:with-live",
    "charts:dev": "bun run --cwd ./charts dev",
    "charts:playground": "bun run --cwd ./charts dev:svelte",
    "charts:build": "bun run --cwd ./charts build",
    "charts:typecheck": "bun run --cwd ./charts typecheck",
    "traceboost:doctor": "bun run --cwd ./apps/traceboost-demo doctor",
    "traceboost:dev": "bun run --cwd ./apps/traceboost-demo dev",
    "traceboost:typecheck": "bun run --cwd ./apps/traceboost-demo typecheck",
    "traceboost:build": "bun run --cwd ./apps/traceboost-demo build"
  }
}
